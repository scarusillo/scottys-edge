scripts/ziOBVE8R

# v26.0 shadow harness — DB snapshots are 3.4 GB each, regenerable via capture
tests/golden/*/_snapshot.db
tests/golden/*/_snapshot.db-shm
tests/golden/*/_snapshot.db-wal
# Transient verification artifacts (regenerable on demand)
tests/golden/_det_*/

# Local data salvage files (not part of any pipeline)
data/*.salvaged.json
data/cowork_comments.corrupt.*.json
